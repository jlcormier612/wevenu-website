# Wevenu Marketing — local environment
#
# Copy to .env.local and fill values from the Stripe Dashboard.

NEXT_PUBLIC_MARKETING_URL=http://localhost:3001

# Stripe (SaaS billing for Wevenu subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Recurring Price IDs (Products → Prices in Stripe Dashboard)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWING=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
